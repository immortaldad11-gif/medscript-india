# --- Database (Docker Compose defaults) ---
DATABASE_URL="postgresql://medscript:medscript_dev@localhost:5432/medscript?schema=public"

# --- Redis (Docker Compose defaults) ---
REDIS_URL="redis://localhost:6379"

# --- Rate limiting (Section 3.2) ---
# When Redis is unreachable the limiter fails OPEN by default (allows requests). Set =1
# to fail CLOSED in production: deny auth/OTP during a Redis outage, preserving brute-
# force protection at the cost of availability.
RATE_LIMIT_FAIL_CLOSED="0"

# --- JWT secrets (generate strong values for production) ---
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# --- App-level field encryption key (AES-256-GCM, 32 bytes base64) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY="changeme_changeme_changeme_chang="

# --- Public base URL (used in prescription verification QR codes) ---
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- Notification provider (Gupshup WhatsApp Business API) ---
# Leave NOTIFICATIONS_DRIVER=log in development to print messages to console.
NOTIFICATIONS_DRIVER="log"
GUPSHUP_API_KEY=""
GUPSHUP_SOURCE_NUMBER=""
GUPSHUP_APP_NAME=""

# --- 2FA ---
TWOFA_ISSUER="MedScript India"
# Dev-only fixed TOTP bypass for when the host clock is skewed from the authenticator
# app (sandboxed dev). Ignored when NODE_ENV=production. Leave empty in production.
DEV_TOTP_BYPASS=""

# --- Async pipeline (BullMQ) ---
# QUEUE_ENABLED=1 offloads OCR + notification delivery to the worker (`npm run worker`).
# Leave 0/unset to run them inline in the request (single-process dev).
QUEUE_ENABLED="0"

# --- ABDM / ABHA health-ID linking ---
# Dev-only fixed OTP accepted by the ABHA link flow. Ignored when NODE_ENV=production.
ABHA_DEV_OTP="123456"

# --- DSC (Digital Signature Certificate) signing ---
# Production: base64-encoded PEM signing key (eMudhra/HSM export) + CCA cert metadata.
# When unset, a persisted dev RSA-2048 keyring is generated under storage/.dsc/ and can
# be rotated in-app (Signing Keys admin page). Env/HSM-managed keys disable in-app rotation.
DSC_PRIVATE_KEY_PEM=""
DSC_PUBLIC_KEY_PEM=""
DSC_CERT_SERIAL=""

# --- Document storage (Section 4.3) ---
# STORAGE_DRIVER=local keeps encrypted files on disk under storage/ (dev default).
# STORAGE_DRIVER=s3 stores them in AWS S3 (or any S3-compatible store via S3_ENDPOINT).
# Bytes are ALWAYS app-encrypted (AES-256-GCM) before upload regardless of driver.
STORAGE_DRIVER="local"
S3_BUCKET=""
S3_REGION="ap-south-1"
# S3_ENDPOINT: set for MinIO / LocalStack (e.g. http://localhost:9000); leave empty for AWS.
S3_ENDPOINT=""
# S3_FORCE_PATH_STYLE=1 for MinIO/LocalStack (auto-on when S3_ENDPOINT is set).
S3_FORCE_PATH_STYLE=""
# Optional key prefix within the bucket (e.g. "documents/").
S3_PREFIX=""
# Server-side encryption: "AES256" (SSE-S3, default), "aws:kms" (+ S3_KMS_KEY_ID), or "none".
S3_SSE="AES256"
S3_KMS_KEY_ID=""
# AWS credentials come from the standard chain (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY,
# instance/role, or SSO). Set them in the environment when STORAGE_DRIVER=s3.
